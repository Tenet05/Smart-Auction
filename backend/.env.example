# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/smartauction

# JWT / cookies
JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_EXPIRE=7d
COOKIE_EXPIRE=7

# Frontend URL(s) allowed by CORS — comma-separate if you have more than one
# (e.g. a Vercel preview + your production domain). *.vercel.app and *.netlify.app
# are always allowed automatically.
FRONTEND_URL=http://localhost:5173

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Brevo (transactional email — OTPs, notifications, admin escalations)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@smartauction.com
BREVO_SENDER_NAME=SmartAuction

# Admin inbox that receives chatbot escalations and other admin alerts
ADMIN_EMAIL=app.smartauctions@gmail.com

# Razorpay (payments) — leave blank to run payments in simulated/test mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Groq (free OpenAI-compatible AI API) — used for AI descriptions, price
# predictions, and the support chatbot. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
